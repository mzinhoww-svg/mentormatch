// MentorMatch — Prisma schema.
//
// Source of truth for table shapes. RLS lives in raw-SQL migrations (ADR-002),
// not here. Tenant-scoped tables are reachable only through withTenant().
// `tenant` is the registry (NOT tenant-scoped). All other tables carry RLS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled, app role (mm_app)
  directUrl = env("DIRECT_URL") // direct, owner role (mm_owner) — migrations
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  domains     TenantDomain[]
  users       TenantUser[]
  consents    ConsentRecord[]
  auditEvents AuditEvent[]
  profiles    Profile[]
  skills      Skill[]
  userSkills  UserSkill[]
  goals       DevelopmentGoal[]
  requests    MentorshipRequest[]
  mentorships Mentorship[]
  sessions    MentorshipSession[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  programs            Program[]
  programParticipants ProgramParticipant[]
  settings            TenantSettings?
  feedback            Feedback[]
  emails              EmailMessage[]

  @@map("tenant")
}

/// Platform operators (cross-tenant). Owner-only registry: no RLS and no mm_app
/// grant, so password hashes are unreachable by the app role (see migration 0012).
model PlatformAdmin {
  id              String   @id @default(uuid()) @db.Uuid
  email           String
  normalizedEmail String   @unique @map("normalized_email")
  displayName     String?  @map("display_name")
  passwordHash    String   @map("password_hash")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_admin")
}

model TenantDomain {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  domain            String    @unique
  isPrimary         Boolean   @default(false) @map("is_primary")
  verified          Boolean   @default(false)
  verificationToken String?   @map("verification_token")
  verifiedAt        DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_domain")
}

model TenantUser {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  email           String
  normalizedEmail String   @map("normalized_email")
  displayName     String?  @map("display_name")
  role            String   @default("member")
  passwordHash    String?  @map("password_hash")
  status          String   @default("active")
  contactEmail    String?  @map("contact_email")
  contactPhone    String?  @map("contact_phone")
  contactWhatsapp String?  @map("contact_whatsapp")
  contactPublic   Boolean  @default(false) @map("contact_public")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consents            ConsentRecord[]
  profile             Profile?
  skills              UserSkill[]
  goals               DevelopmentGoal[]
  requestsAsMentee    MentorshipRequest[] @relation("RequestMentee")
  requestsAsMentor    MentorshipRequest[] @relation("RequestMentor")
  mentorshipsAsMentor Mentorship[]        @relation("MentorshipMentor")
  mentorshipsAsMentee Mentorship[]        @relation("MentorshipMentee")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  programParticipations   ProgramParticipant[]
  feedbackAuthored        Feedback[]

  @@unique([tenantId, normalizedEmail])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("tenant_user")
}

model ConsentRecord {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenantUserId String   @map("tenant_user_id") @db.Uuid
  termsVersion String   @map("terms_version")
  consentedAt  DateTime @default(now()) @map("consented_at") @db.Timestamptz(6)
  ip           String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("consent_record")
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  action     String
  actorId    String?  @map("actor_id") @db.Uuid
  actorType  String?  @map("actor_type")
  targetId   String?  @map("target_id") @db.Uuid
  targetType String?  @map("target_type")
  metadata   Json?
  requestId  String?  @map("request_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("audit_event")
}

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  tenantUserId    String   @unique @map("tenant_user_id") @db.Uuid
  bio             String?
  title           String?
  area            String?
  seniority       String?
  avatarUrl       String?  @map("avatar_url")
  linkedinUrl     String?  @map("linkedin_url")
  status          String   @default("inactive")
  mentorAvailable Boolean  @default(false) @map("mentor_available")
  mentorPaused    Boolean  @default(false) @map("mentor_paused")
  mentorCapacity  Int      @default(3) @map("mentor_capacity")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("profile")
}

model Skill {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  normalizedName String   @map("normalized_name")
  category       String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userSkills UserSkill[]

  @@unique([tenantId, normalizedName])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("skill")
}

model UserSkill {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenantUserId String   @map("tenant_user_id") @db.Uuid
  skillId      String   @map("skill_id") @db.Uuid
  relation     String // offered | sought | interest
  level        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tenantUserId, skillId, relation])
  @@index([tenantId, tenantUserId])
  @@map("user_skill")
}

model DevelopmentGoal {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenantUserId String   @map("tenant_user_id") @db.Uuid
  description  String
  status       String   @default("open")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("development_goal")
}

model MentorshipRequest {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  menteeId  String    @map("mentee_id") @db.Uuid
  mentorId  String    @map("mentor_id") @db.Uuid
  skillId   String?   @map("skill_id") @db.Uuid
  message   String?
  status    String    @default("pending")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt DateTime? @map("decided_at") @db.Timestamptz(6)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mentee TenantUser @relation("RequestMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  mentor TenantUser @relation("RequestMentor", fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([tenantId, mentorId])
  @@index([tenantId, menteeId])
  @@map("mentorship_request")
}

model Mentorship {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  mentorId  String    @map("mentor_id") @db.Uuid
  menteeId  String    @map("mentee_id") @db.Uuid
  requestId String?   @map("request_id") @db.Uuid
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  endedAt   DateTime? @map("ended_at") @db.Timestamptz(6)

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mentor   TenantUser           @relation("MentorshipMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  mentee   TenantUser           @relation("MentorshipMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  sessions MentorshipSession[]

  @@unique([tenantId, id], map: "uq_mentorship_tenant_id")
  @@index([tenantId, mentorId])
  @@index([tenantId, menteeId])
  @@map("mentorship")
}

model MentorshipSession {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  mentorshipId String    @map("mentorship_id") @db.Uuid
  requestedBy  String    @map("requested_by") @db.Uuid
  scheduledAt  DateTime? @map("scheduled_at") @db.Timestamptz(6)
  objective    String?
  notes        String?
  status       String    @default("requested")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  confirmedAt  DateTime? @map("confirmed_at") @db.Timestamptz(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelReason String?   @map("cancel_reason")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mentorship Mentorship @relation(fields: [tenantId, mentorshipId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, mentorshipId])
  @@index([tenantId, status])
  @@map("mentorship_session")
}

model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  targetUserId  String    @map("target_user_id") @db.Uuid
  type          String
  payload       Json      @default("{}")
  status        String    @default("unread")
  originEvent   String    @map("origin_event")
  originAuditId String?   @map("origin_audit_id") @db.Uuid
  emailStatus   String    @default("none") @map("email_status")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt        DateTime? @map("read_at") @db.Timestamptz(6)

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  target TenantUser @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  emails EmailMessage[]

  @@index([tenantId, targetUserId, status])
  @@index([tenantId, createdAt])
  @@map("notification")
}

model EmailMessage {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  notificationId String?  @unique @map("notification_id") @db.Uuid
  recipient      String
  templateKey    String   @map("template_key")
  subject        String
  body           String
  originEvent    String   @map("origin_event")
  status         String   @default("pending")
  provider       String?
  attempts       Int      @default(0)
  lastError      String?  @map("last_error")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("email_message")
}

model NotificationPreference {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenantUserId String   @map("tenant_user_id") @db.Uuid
  type         String
  inApp        Boolean  @default(true) @map("in_app")
  email        Boolean  @default(false)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tenantUserId, type], map: "uq_pref")
  @@map("notification_preference")
}

model Program {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  status      String   @default("active")
  isDefault   Boolean  @default(false) @map("is_default")
  capacity    Int?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participants ProgramParticipant[]

  @@unique([tenantId, id], map: "uq_program_tenant_id")
  @@index([tenantId])
  @@map("program")
}

model ProgramParticipant {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  programId     String   @map("program_id") @db.Uuid
  tenantUserId  String   @map("tenant_user_id") @db.Uuid
  roleInProgram String   @default("member") @map("role_in_program")
  status        String   @default("active")
  joinedAt      DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program Program    @relation(fields: [tenantId, programId], references: [tenantId, id], onDelete: Cascade)
  user    TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, programId, tenantUserId], map: "uq_participant")
  @@index([tenantId, programId])
  @@map("program_participant")
}

model TenantSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @unique @map("tenant_id") @db.Uuid
  displayName           String?  @map("display_name")
  logoUrl               String?  @map("logo_url")
  primaryColor          String?  @map("primary_color")
  secondaryColor        String?  @map("secondary_color")
  fontFamily            String?  @map("font_family")
  borderRadius          String?  @map("border_radius")
  programName           String?  @map("program_name")
  locale                String   @default("pt-BR")
  status                String   @default("active")
  allowSelfSignup       Boolean  @default(true) @map("allow_self_signup")
  defaultMentorCapacity Int      @default(3) @map("default_mentor_capacity")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Feedback {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  authorId     String   @map("author_id") @db.Uuid
  feedbackType String   @map("feedback_type")
  targetType   String   @map("target_type")
  targetId     String   @map("target_id") @db.Uuid
  mentorshipId String?  @map("mentorship_id") @db.Uuid
  score        Int
  comment      String?
  status       String   @default("submitted")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author TenantUser @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, targetType, targetId])
  @@index([tenantId, authorId])
  @@map("feedback")
}
