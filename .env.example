# =============================================================================
# MentorMatch — Environment Variables (EXAMPLE / TEMPLATE)
# -----------------------------------------------------------------------------
# This file documents EVERY environment variable the application and its
# infrastructure (Vercel / Supabase / Vercel Blob) are expected to use.
#
# RULES:
#   - NEVER commit real secrets. This file holds placeholders ONLY.
#   - Copy to `.env.local` for local development and fill in real values there.
#   - `.env.local` MUST be git-ignored.
#   - In Vercel, set these under Project Settings → Environment Variables,
#     scoped to Production / Preview / Development as noted in docs/ENVIRONMENT.md.
#
# Legend used in docs/ENVIRONMENT.md:
#   [APP]    = you set this manually (app-managed)
#   [AUTO]   = injected automatically by the Vercel/Supabase integration
#   [BLOB]   = injected automatically by the Vercel Blob integration
#   [PUBLIC] = exposed to the browser (NEXT_PUBLIC_*) — never a secret
# =============================================================================


# -----------------------------------------------------------------------------
# APP — manually managed (set in Vercel + local .env.local)
# -----------------------------------------------------------------------------
# APP_ENV: logical environment of the running app.
#   one of: development | preview | production
APP_ENV=development

# APP_BASE_DOMAIN: root domain used to build tenant URLs (no protocol).
#   local example: mentormatch.local   prod example: mentormatch.app
APP_BASE_DOMAIN=mentormatch.local

# TENANT_DOMAIN_MODE: how a tenant is resolved from the request host.
#   one of: subdomain | path | custom
TENANT_DOMAIN_MODE=subdomain

# NEXT_PUBLIC_APP_URL: absolute base URL of the app (protocol + host).
#   [PUBLIC] — safe to expose to the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# AUTH (Auth.js / NextAuth)
# -----------------------------------------------------------------------------
# AUTH_SECRET: secret used to sign/encrypt session tokens.
#   Generate with: openssl rand -base64 32
AUTH_SECRET=

# AUTH_TRUST_HOST: trust the incoming Host header (required behind Vercel proxy).
AUTH_TRUST_HOST=true


# -----------------------------------------------------------------------------
# ENCRYPTION — application-level secret encryption (field/value encryption)
# -----------------------------------------------------------------------------
# ENCRYPTION_KEY: 32-byte key (base64 or hex) for at-rest encryption of
#   sensitive fields. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# PLATFORM ADMIN — one-time bootstrap of the first platform-level admin
# -----------------------------------------------------------------------------
# PLATFORM_ADMIN_EMAIL: email of the initial platform super-admin.
PLATFORM_ADMIN_EMAIL=

# PLATFORM_ADMIN_NAME: display name of the initial platform super-admin.
PLATFORM_ADMIN_NAME=

# PLATFORM_ADMIN_BOOTSTRAP_TOKEN: one-time token gating the bootstrap route.
#   Rotate/remove after first successful bootstrap.
PLATFORM_ADMIN_BOOTSTRAP_TOKEN=


# -----------------------------------------------------------------------------
# DATABASE — Prisma aliases (REQUIRED by the app)
# -----------------------------------------------------------------------------
# IMPORTANT — Prisma + Supabase/Vercel Postgres convention:
#   DATABASE_URL  MUST be a copy of  POSTGRES_PRISMA_URL      (pooled, pgbouncer)
#   DIRECT_URL    MUST be a copy of  POSTGRES_URL_NON_POOLING (direct, migrations)
# Prisma uses DATABASE_URL for runtime queries (pooled) and DIRECT_URL for
# migrations / introspection (direct connection, no pgbouncer).
DATABASE_URL=
DIRECT_URL=


# -----------------------------------------------------------------------------
# VERCEL / SUPABASE — auto-injected by the integration ([AUTO])
# Do NOT set these by hand in normal operation; the integration provides them.
# Listed here for documentation/visibility only.
# -----------------------------------------------------------------------------
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# [PUBLIC] Supabase client-side values (safe to expose):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=


# -----------------------------------------------------------------------------
# VERCEL BLOB — file storage ([BLOB])
# -----------------------------------------------------------------------------
# BLOB_READ_WRITE_TOKEN: read/write token for the Blob store (secret).
BLOB_READ_WRITE_TOKEN=

# BLOB_STORE_ID: identifier of the Blob store (auto-injected).
BLOB_STORE_ID=

# BLOB_WEBHOOK_PUBLIC_KEY: public key to verify Blob webhook signatures.
BLOB_WEBHOOK_PUBLIC_KEY=
